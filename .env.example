# RM Buddy Environment Variables
# Copy this to .env and fill in values

# Common
NODE_ENV=development
LOG_LEVEL=debug

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/rm-buddy?retryWrites=true&w=majority

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=rm-buddy

# Auth (SSO)
JWT_SECRET=your-jwt-secret-change-in-production
SSO_ENDPOINT=https://auth.nuvama.com/oauth2
SSO_CLIENT_ID=rm-buddy-client
SSO_CLIENT_SECRET=your-sso-secret

# LiteLLM
LITELLM_URL=http://localhost:4000
LITELLM_MASTER_KEY=your-litellm-key

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_AGENT_ID=your-agent-id

# Service Ports
GATEWAY_PORT=3000
CORE_API_PORT=3001
AUTH_SERVICE_PORT=3002
COMM_SERVICE_PORT=3003
LITELLM_PORT=4000
AGENT_PORT=5000
FRONTEND_PORT=5173
